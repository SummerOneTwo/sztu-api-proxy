SZTU_API_KEY=sk-your-sztu-key
SZTU_DEFAULT_MODEL=deepseek-v4-pro

# Optional ports
OPENCODE_PROXY_PORT=8788
CLAUDE_SZTU_PROXY_PORT=8790
CODEBUDDY_PROXY_PORT=8787

# Optional token limits
SZTU_DEFAULT_MAX_TOKENS=32768
SZTU_MAX_TOKENS=32768
SZTU_THINKING_MIN_MAX_TOKENS=10000

# Claude Code tool bridge: native OpenAI tool_calls by default.
# Use prompt to fall back to prompt-mediated XML/JSON parsing.
CLAUDE_SZTU_TOOL_MODE=native
# SZTU rejects assistant tool_calls/role=tool in request history today.
# Use structured only for future fully OpenAI-compatible backends.
CLAUDE_SZTU_TOOL_HISTORY_MODE=text
