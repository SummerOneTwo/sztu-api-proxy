{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "sztu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SZTU API Gateway",
      "options": {
        "baseURL": "http://127.0.0.1:8788/v1",
        "apiKey": "any",
        "timeout": 600000,
        "chunkTimeout": 600000
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek-V4-Pro",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "chat_template_kwargs": {
              "thinking": false
            }
          },
          "variants": {
            "high": {
              "chat_template_kwargs": {
                "thinking": true,
                "reasoning_effort": "high"
              }
            },
            "max": {
              "chat_template_kwargs": {
                "thinking": true,
                "reasoning_effort": "max"
              }
            }
          }
        }
      }
    }
  },
  "experimental": {
    "mcp_timeout": 15000
  }
}
